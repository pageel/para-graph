{
  "name": "para-graph",
  "version": "0.8.1",
  "description": "Hybrid Code-Knowledge Graph tool for PARA Workspace",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "para-graph": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/graph/code-graph.d.ts",
      "import": "./dist/graph/code-graph.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "files": [
    "dist/",
    "src/queries/",
    "templates/"
  ],
  "scripts": {
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json && rm -rf dist/queries && cp -r src/queries dist/queries"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pageel/para-graph.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/pageel/para-graph/issues"
  },
  "homepage": "https://github.com/pageel/para-graph#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-bash": "^0.21.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2"
  }
}
